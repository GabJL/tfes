---
import type { CollectionEntry } from "astro:content";

interface Props {
  category: CollectionEntry<"categories">;
}

const { category } = Astro.props;
---

<span
  class="category-badge"
  style={`--category-color: ${category.data.color}`}
  title={category.data.name}
>
  {category.data.name}
</span>