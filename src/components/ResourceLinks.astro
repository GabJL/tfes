---
import { withBase } from "../lib/paths";

interface Resources {
  thesis?: string;
  proposal?: string;
  repository?: string;
  paper?: string;
  slides?: string;
  poster?: string;
  video?: string;
}

interface Props {
  resources?: Resources;
  compact?: boolean;
}

const {
  resources,
  compact = false,
} = Astro.props;

const definitions = [
  {
    key: "thesis",
    label: "Memoria",
    compactLabel: "PDF",
    icon: "📄",
  },
  {
    key: "proposal",
    label: "Anteproyecto",
    compactLabel: "Anteproyecto",
    icon: "📄",
  },
  {
    key: "repository",
    label: "Repositorio",
    compactLabel: "Código",
    icon: "⌨",
  },
  {
    key: "paper",
    label: "Publicación",
    compactLabel: "Artículo",
    icon: "▤",
  },
  {
    key: "slides",
    label: "Presentación",
    compactLabel: "Diapositivas",
    icon: "▣",
  },
  {
    key: "poster",
    label: "Póster",
    compactLabel: "Póster",
    icon: "▥",
  },
  {
    key: "video",
    label: "Vídeo",
    compactLabel: "Vídeo",
    icon: "▶",
  },
] as const;

const links = resources
  ? definitions
      .map(({ key, label, compactLabel, icon }) => {
        const url = resources[key];

        if (!url) {
          return undefined;
        }

        const external = /^https?:\/\//i.test(url);
        const pdf = /\.pdf(?:$|\?)/i.test(url);

        return {
          label,
          compactLabel,
          icon,
          href: external ? url : withBase(url),
          newTab: external || pdf,
        };
      })
      .filter((link) => link !== undefined)
  : [];
---

{
  links.length > 0 && compact && (
    <nav
      class="resource-links-compact"
      aria-label="Recursos del trabajo"
    >
      {
        links.map((resource) => (
          <a
            href={resource.href}
            target={resource.newTab ? "_blank" : undefined}
            rel={resource.newTab ? "noopener noreferrer" : undefined}
            title={resource.label}
          >
            {resource.compactLabel}
          </a>
        ))
      }
    </nav>
  )
}

{
  links.length > 0 && !compact && (
    <section class="resource-links">
      <h2>Recursos</h2>

      <div class="resource-links__list">
        {
          links.map((resource) => (
            <a
              href={resource.href}
              target={resource.newTab ? "_blank" : undefined}
              rel={resource.newTab ? "noopener noreferrer" : undefined}
            >
              <span
                class="resource-links__icon"
                aria-hidden="true"
              >
                {resource.icon}
              </span>

              <span>{resource.label}</span>
            </a>
          ))
        }
      </div>
    </section>
  )
}