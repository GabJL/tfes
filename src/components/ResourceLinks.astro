---
import { withBase } from "../lib/paths";

interface Resources {
  thesis?: string;
  proposal?: string;
  repository?: string;
  paper?: string;
  slides?: string;
  poster?: string;
  video?: string;
}

interface Props {
  resources?: Resources;
}

const { resources } = Astro.props;

function resolveResource(url: string): string {
  return /^https?:\/\//.test(url)
    ? url
    : withBase(url);
}

const links = resources
  ? [
      { label: "Memoria", url: resources.thesis },
      { label: "Anteproyecto", url: resources.proposal },
      { label: "Repositorio", url: resources.repository },
      { label: "Publicación", url: resources.paper },
      { label: "Presentación", url: resources.slides },
      { label: "Póster", url: resources.poster },
      { label: "Vídeo", url: resources.video },
    ]
      .filter(
        (resource): resource is { label: string; url: string } =>
          Boolean(resource.url)
      )
      .map((resource) => ({
        ...resource,
        resolvedUrl: resolveResource(resource.url),
        external: /^https?:\/\//.test(resource.url),
      }))
  : [];
---
{
  links.length > 0 && (
    <section class="resource-links">
      <h2>Recursos</h2>

      <ul>
        {
          links.map((resource) => (
            <li>
              <a
                href={resource.resolvedUrl}
                target={resource.external ? "_blank" : undefined}
                rel={resource.external ? "noopener noreferrer" : undefined}
              >
                {resource.label}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  )
}